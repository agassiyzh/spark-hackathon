# Presets for Gemma 4 on DGX Spark:
# Stable:
# MAX_MODEL_LEN=4096
# MAX_NUM_SEQS=1
# GPU_MEMORY_UTILIZATION=0.50
#
# Balanced:
MAX_NUM_SEQS=32
MAX_MODEL_LEN=262144
GPU_MEMORY_UTILIZATION=0.55
#
# Aggressive:
# MAX_MODEL_LEN=16384
# MAX_NUM_SEQS=1
# GPU_MEMORY_UTILIZATION=0.60
TENSOR_PARALLEL_SIZE=1
HF_HOME=./model_cache/huggingface
OPEN_WEBUI_DATA_DIR=./data/open-webui
