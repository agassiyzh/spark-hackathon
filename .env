ORCH_DATA_DIR=./orchestrator_data
HA_BASE_URL=http://host.docker.internal:8123
HA_TOKEN=
LLM_API_KEY=sk-local-dummy-key
AUTO_EXECUTE_ENTITIES=light.living_room
EMBEDDING_PORT=7997
RERANKER_PORT=7998
EMBEDDING_MODEL_ID=BAAI/bge-m3
RERANKER_MODEL_ID=BAAI/bge-reranker-v2-m3
